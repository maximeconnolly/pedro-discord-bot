# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: a dev guild id for instant slash-command registration
DISCORD_GUILD_ID=

# Database
DATABASE_URL=postgres://raccoon:raccoon@postgres:5432/raccoon

# Logging
LOG_LEVEL=info

# AI provider: noop (stub) or digitalocean (DO serverless inference)
AI_PROVIDER=noop
# Required when AI_PROVIDER=digitalocean:
# AI_BASE_URL=https://inference.do-ai.run/v1
# AI_API_KEY=dop_v1_...
# AI_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# CTFtime integration
# The bot requires the MANAGE_EVENTS Discord permission to create and update
# Guild Scheduled Events. No API key is needed; CTFtime's API is public.
